{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.simsig.vgsmr",
  "productName": "vGSM-R",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "images/**/*",
    "sounds/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "src/main/*.ps1",
    "node_modules/uiohook-napi/**/*"
  ],
  "publish": {
    "provider": "github",
    "owner": "fcooper94",
    "repo": "SimSig-vGSM-R"
  },
  "win": {
    "target": "squirrel",
    "icon": "images/icon.png",
    "requestedExecutionLevel": "asInvoker"
  },
  "squirrelWindows": {
    "iconUrl": "https://raw.githubusercontent.com/fcooper94/SimSig-vGSM-R/main/images/icon.png",
    "setupIcon": "images/icon.png",
    "artifactName": "vGSM-R-Setup-${version}.${ext}",
    "shortcutName": "vGSM-R",
    "createDesktopShortcut": true
  }
}
